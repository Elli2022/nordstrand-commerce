# ── Database (Docker Compose default) ─────────────────────
DATABASE_URL=postgresql://nordstrand:nordstrand@localhost:5432/nordstrand

# ── API (apps/api) ───────────────────────────────────────
API_PORT=4000
API_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# Stripe — https://dashboard.stripe.com/test/apikeys
# Lämna placeholders tills du har riktiga nycklar — då körs demo-checkout automatiskt.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# CHECKOUT_MODE=demo   # default när Stripe-nycklar saknas
# CHECKOUT_MODE=stripe # kräver riktiga Stripe testnycklar

# ── Web (apps/web) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
