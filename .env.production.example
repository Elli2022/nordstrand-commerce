# Produktion — kopiera värden till Render och Netlify

# ── Render (API) ──────────────────────────────────────────
DATABASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_MODE=stripe
CORS_ORIGIN=https://nordstrand-commerce.netlify.app
API_PORT=4000
API_BASE_URL=https://nordstrand-api.onrender.com

# ── Netlify (butik) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=https://nordstrand-api.onrender.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Stripe webhook (Dashboard, inte env-fil) ────────────────
# Endpoint: https://nordstrand-api.onrender.com/api/v1/webhooks/stripe
# Events: checkout.session.completed, checkout.session.expired
